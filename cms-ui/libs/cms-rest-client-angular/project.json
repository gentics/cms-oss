{
    "name": "cms-rest-client-angular",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/cms-rest-client-angular/src",
    "prefix": "lib",
    "projectType": "library",
    "tags": ["lib", "angular", "publish"],
    "targets": {
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/cms-rest-client-angular/jest.config.cts",
                "tsConfig": "libs/cms-rest-client-angular/tsconfig.spec.json"
            }
        },
        "build": {
            "executor": "@nx/angular:ng-packagr-lite",
            "options": {
                "tsConfig": "libs/cms-rest-client-angular/tsconfig.lib.json",
                "project": "libs/cms-rest-client-angular/ng-package.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/cms-rest-client-angular/tsconfig.lib.prod.json"
                },
                "development": {}
            },
            "defaultConfiguration": "production"
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
