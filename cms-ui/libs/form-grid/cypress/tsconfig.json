{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "node16",
        "allowJs": true,
        "outDir": "../../dist/out-tsc",
        "module": "commonjs",
        "types": ["cypress", "node"],
        "sourceMap": false
    },
    "include": [
        "**/*.ts",
        "**/*.js",
        "../cypress.config.ts",
        "../src/**/*.cy.ts",
        "../src/**/*.cy.js",
        "../src/**/*.d.ts"
    ],
    "exclude": [
        "**/*.spec.ts",
        "../src/test.ts",
        "../testing/**/*",
        "../build/**/*"
    ]
}
