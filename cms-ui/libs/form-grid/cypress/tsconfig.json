{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "node10",
        "allowJs": true,
        "outDir": "../../dist/out-tsc",
        "module": "commonjs",
        "types": ["cypress", "node"],
        "sourceMap": false
    },
    "include": [
        "**/*.ts",
        "**/*.js",
        "../cypress.config.ts",
        "../**/*.cy.ts",
        "../**/*.cy.js",
        "../**/*.d.ts"
    ]
}
