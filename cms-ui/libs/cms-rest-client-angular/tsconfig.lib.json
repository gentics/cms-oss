{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["node", "jquery"]
    },
    "include": ["src/**/*.ts", "testing/src/**/*.ts"],
    "exclude": [
        "src/**/*.spec.ts",
        "src/**/*.test.ts",
        "jest.config.ts",
        "jest.config.cts",
        "src/test-setup.ts",
        "testing/src/**/*.spec.ts",
        "testing/src/**/*.test.ts"
    ]
}
