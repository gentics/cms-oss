{
    "name": "form-grid",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "gtx",
    "sourceRoot": "libs/form-grid/src",
    "tags": ["lib", "angular", "publish"],
    "targets": {
        "build": {
            "executor": "@nx/angular:ng-packagr-lite",
            "options": {
                "tsConfig": "libs/form-grid/tsconfig.lib.json",
                "project": "libs/form-grid/ng-package.json"
            },
            "configurations": {
                "production": {},
                "development": {},
                "ci": {}
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/form-grid/jest.config.ts",
                "tsConfig": "libs/form-grid/tsconfig.spec.json"
            }
        }
    }
}
