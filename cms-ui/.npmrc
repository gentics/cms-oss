# Increase node memory limit to 5120M
node-options = --max-old-space-size=5120
# Add the registry
@gentics:registry=https://repo.gentics.com/repository/npm-products/
# Until fixing legacy dependency of Gentics UI Image Editor
legacy-peer-deps = true
git-tag-version = false
allow-same-version = true
fund=false
audit=false
