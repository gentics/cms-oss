{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["node", "jquery"]
    },
    "include": [
        "src/**/*.ts",
        "testing/src/**/*.ts",
        "aloha/src/**/*.ts",
        "auth/src/**/*.ts"
    ],
    "exclude": [
        "cypress.*.ts",
        "cypress/**",
        "karma.conf.js",
        "src/**/*.spec.ts",
        "src/**/*.cy.ts",
        "testing/src/**/*.spec.ts",
        "testing/src/**/*.cy.ts",
        "aloha/src/**/*.spec.ts",
        "aloha/src/**/*.cy.ts",
        "auth/src/**/*.spec.ts",
        "auth/src/**/*.cy.ts"
    ]
}
