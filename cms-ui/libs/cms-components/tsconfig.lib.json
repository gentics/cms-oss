{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["node", "jquery", "jasmine"]
    },
    "include": [
        "src/**/*.ts",
        "testing/src/**/*.ts",
        "aloha/src/**/*.ts",
        "auth/src/**/*.ts"
    ],
    "exclude": [
        "cypress/**/*",
        "cypress.*.ts",
        "**/*.spec.ts",
        "**/*.cy.ts"
    ]
}
