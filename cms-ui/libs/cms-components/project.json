{
    "name": "cms-components",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "gtx",
    "sourceRoot": "libs/cms-components/src",
    "tags": ["lib", "angular", "publish"],
    "targets": {
        "build": {
            "executor": "@nx/angular:ng-packagr-lite",
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
            "options": {
                "project": "libs/cms-components/ng-package.json",
                "tsConfig": "libs/cms-components/tsconfig.lib.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/cms-components/tsconfig.lib.prod.json"
                },
                "development": {}
            },
            "defaultConfiguration": "production"
        },
        "test": {
            "executor": "@angular-devkit/build-angular:karma",
            "options": {
                "main": "{projectRoot}/src/test.ts",
                "polyfills": ["zone.js", "zone.js/testing"],
                "tsConfig": "{projectRoot}/tsconfig.spec.json",
                "karmaConfig": "{projectRoot}/karma.conf.js",
                "stylePreprocessorOptions": {
                    "includePaths": ["{projectRoot}/src/styles"]
                },
                "watch": false
            },
            "configurations": {
                "ci": {
                    "codeCoverage": true,
                    "reporters": ["junit"],
                    "browsers": "ChromeDocker",
                    "progress": false
                },
                "watch": {
                    "watch": true
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "component-test": {
            "executor": "@nx/cypress:cypress",
            "options": {
                "cypressConfig": "{projectRoot}/cypress.config.ts",
                "testingType": "component",
                "skipServe": true,
                "devServerTarget": "component-tests-harness:build"
            },
            "configurations": {
                "ci": {
                    "quiet": true,
                    "cypressConfig": "{projectRoot}/cypress.config.ci.ts",
                    "devServerTarget": "component-tests-harness:build:ci"
                }
            }
        }
    }
}
