{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["jasmine"]
    },
    "include": ["src/**/*.ts", "testing/src/**/*.ts"],
    "exclude": [
        "cypress/**/*",
        "cypress.*.ts",
        "**/*.spec.ts",
        "**/*.cy.ts",
        "cypress.config.ts",
        "**/*.cy.js",
        "**/*.cy.tsx",
        "**/*.cy.jsx"
    ]
}
