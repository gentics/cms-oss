{
    // General Settings
    "editor.accessibilityPageSize": 10,
    "files.eol": "\n",
    "files.associations": {
        "*.es": "json",
        "part.*.html": "velocity",
        "*.textile": "asciidoc",
        // Force regular JSON, not with comments, as *somewhere* in the building process,
        // this causes the entire build system to just break.
        "tsconfig.json": "json",
        "tsconfig.*.json": "json"
    },
    // Plugin Settings
    "redhat.telemetry.enabled": false,
    // Language Settings
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[javascript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "js/ts.preferences.autoImportFileExcludePatterns": [
        "@angular/compiler",
        "hammerjs"
    ],
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "angular.enable-strict-mode-prompt": false,
    "eslint.useFlatConfig": true,
    "eslint.format.enable": true,
    "eslint.enable": true,
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    "nxConsole.nxWorkspacePath": "cms-ui"
}
