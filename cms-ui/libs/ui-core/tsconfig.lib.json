{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["jasmine"]
    },
    "include": [
        "src/**/*.ts",
        "testing/src/**/*.ts"
    ],
    "exclude": [
        "cypress/**",
        "cypress/*.ts",
        "src/**/*.spec.ts",
        "src/**/*.cy.ts",
        "src/test.ts",
        "testing/src/**/*.spec.ts",
        "testing/src/**/*.cy.ts"
    ]
}
