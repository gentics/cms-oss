{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "module": "commonjs",
        "target": "es2016",
        "types": ["jasmine", "node", "jquery"],
        "moduleResolution": "node10",
        "esModuleInterop": true
    },
    "files": ["src/test-setup.ts"],
    "include": [
        "jest.config.ts",
        "src/**/*.test.ts",
        "src/**/*.spec.ts",
        "src/**/*.d.ts"
    ]
}
