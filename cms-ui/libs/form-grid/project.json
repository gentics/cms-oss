{
    "name": "form-grid",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "gtx",
    "sourceRoot": "libs/form-grid/src",
    "tags": ["lib", "angular", "publish"],
    "targets": {
        "build": {
            "executor": "@nx/angular:package",
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
            "options": {
                "project": "libs/form-grid/ng-package.json",
                "tsConfig": "libs/form-grid/tsconfig.lib.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/form-grid/tsconfig.lib.prod.json"
                },
                "development": {}
            },
            "defaultConfiguration": "production"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/.reports/{projectRoot}/JEST-report.xml",
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "{projectRoot}/jest.config.ts"
            },
            "configurations": {
                "watch": {
                    "watch": true
                },
                "ci": {
                    "color": false,
                    "colors": false,
                    "ci": true,
                    "jestConfig": "{projectRoot}/jest.config.ci.ts"
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "component-test": {
            "executor": "@nx/cypress:cypress",
            "options": {
                "cypressConfig": "{projectRoot}/cypress.config.ts",
                "testingType": "component",
                "skipServe": true,
                "devServerTarget": "component-tests-harness:build"
            },
            "configurations": {
                "ci": {
                    "quiet": true,
                    "cypressConfig": "{projectRoot}/cypress.config.ci.ts",
                    "devServerTarget": "component-tests-harness:build:ci"
                }
            }
        }
    }
}
