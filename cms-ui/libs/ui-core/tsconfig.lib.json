{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "types": ["jasmine"]
    },
    "include": ["src/**/*.ts", "testing/src/**/*.ts", " cypress/src/**/*.ts"],
    "exclude": [
        "cypress/fixtures/**/*",
        "cypress/support/**/*",
        "cypress.config.ts",
        "**/*.spec.ts",
        "**/*.cy.ts"
    ]
}
